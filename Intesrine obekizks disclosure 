import numpy as np
from dataclasses import dataclass
from typing import Optional, Tuple


@dataclass
class ObeliskParameters:
    """Physical parameters of an Obelisk RNA entity."""
    
    # Geometric parameters
    length: float = 50e-9  # 50 nm (typical)
    diameter: float = 5e-9  # 5 nm (typical)
    
    # Material properties
    epsilon_r: float = 4.0  # RNA dielectric constant
    conductivity: float = 1e-3  # S/m (approximate)
    
    # Host parameters
    separation: float = 15e-9  # Distance to enterocyte (m)
    
    # Metal binding (oblin properties)
    zinc_sites: int = 4  # Predicted zinc fingers
    magnesium_sites: int = 2
    silicon_doping: float = 0.01  # Fractional doping level


class ObeliskResonator:
    """
    Models an Obelisk as a cylindrical dielectric resonator.
    
    Calculates resonance frequencies, quality factors, and coupling
    to the external electromagnetic field.
    """
    
    def __init__(self, params: Optional[ObeliskParameters] = None):
        """
        Initialize Obelisk resonator.
        
        Args:
            params: ObeliskParameters instance (creates default if None)
        """
        self.params = params or ObeliskParameters()
        self.c = 299792458  # speed of light (m/s)
        
    def fundamental_frequency(self) -> float:
        """
        Calculate fundamental resonance frequency (TE011 mode).
        
        Returns:
            Frequency in Hz
        """
        r = self.params.diameter / 2
        chi_01 = 2.405  # First root of Bessel function J0
        
        # Cylindrical resonator formula
        f = (self.c / (2 * np.pi * np.sqrt(self.params.epsilon_r))) * (chi_01 / r)
        
        return f
    
    def wavelength(self) -> float:
        """Resonance wavelength in medium."""
        f = self.fundamental_frequency()
        v = self.c / np.sqrt(self.params.epsilon_r)
        return v / f
    
    def quality_factor(self) -> float:
        """
        Calculate quality factor Q = f/Δf.
        
        Higher Q indicates sharper resonance and longer coherence time.
        """
        # Simplified estimate based on dielectric losses
        # Full calculation would include radiation and coupling losses
        tan_delta = 0.01  # Loss tangent (estimated)
        Q_dielectric = 1 / tan_delta
        
        return Q_dielectric
    
    def coherence_time(self) -> float:
        """
        Calculate coherence time τ = Q/ω.
        
        Returns:
            Coherence time in seconds
        """
        omega = 2 * np.pi * self.fundamental_frequency()
        return self.quality_factor() / omega
    
    def evanescent_field(self, distance: Optional[float] = None) -> float:
        """
        Calculate evanescent field strength at given distance.
        
        Args:
            distance: Distance from Obelisk surface (m)
                     (uses params.separation if None)
        
        Returns:
            Relative field strength (0-1)
        """
        if distance is None:
            distance = self.params.separation
            
        lambda_decay = 50e-9  # Decay length in structured water (m)
        return np.exp(-distance / lambda_decay)


class OblinQuantumDot:
    """
    Models oblin proteins as quantum dots.
    
    Calculates energy levels, bandgaps, and metal-binding effects.
    """
    
    def __init__(self, radius: float = 1.5e-9, m_eff: float = 0.1):
        """
        Initialize oblin quantum dot.
        
        Args:
            radius: Quantum dot radius (m)
            m_eff: Effective electron mass (fraction of electron mass)
        """
        self.radius = radius
        self.m_eff = m_eff
        self.m_e = 9.1093837e-31  # Electron mass (kg)
        self.hbar = 1.0545718e-34  # Reduced Planck constant (J·s)
        
    def energy_levels(self, n_max: int = 5) -> np.ndarray:
        """
        Calculate discrete energy levels.
        
        For spherical quantum dot: E_n = (ħ²χ_n²)/(2m*R²)
        
        Args:
            n_max: Maximum quantum number
            
        Returns:
            Array of energy levels in eV
        """
        # Roots of spherical Bessel functions (approximate)
        chi_n = np.array([np.pi, 2*np.pi, 3*np.pi, 4*np.pi, 5*np.pi])[:n_max]
        
        # Calculate energies
        m_star = self.m_eff * self.m_e
        E_joules = (self.hbar**2 * chi_n**2) / (2 * m_star * self.radius**2)
        
        # Convert to eV (1 eV = 1.602e-19 J)
        E_eV = E_joules / 1.602e-19
        
        return E_eV
    
    def bandgap(self) -> float:
        """Energy difference between ground and first excited state."""
        levels = self.energy_levels(2)
        return levels[1] - levels[0]
    
    def metal_shift(self, metal_type: str, concentration: float) -> float:
        """
        Calculate energy shift due to metal binding.
        
        Args:
            metal_type: 'Zn', 'Mg', or 'Si'
            concentration: Fractional occupancy of binding sites
            
        Returns:
            Energy shift in eV
        """
        # Empirical shift coefficients (would be calibrated experimentally)
        shifts = {
            'Zn': 0.15,  # eV per occupied site
            'Mg': 0.08,
            'Si': 0.12
        }
        
        if metal_type not in shifts:
            return 0.0
            
        return shifts[metal_type] * concentration


class ObeliskMicrotubuleInterface:
    """
    Models the coupling between Obelisks and enteric microtubules.
    
    Calculates transmission efficiency, phase preservation,
    and effects of toxins/disruptors.
    """
    
    def __init__(self, obelisk: ObeliskResonator):
        self.obelisk = obelisk
        self.Z0 = 377  # Impedance of free space (Ω)
        
    def coupling_efficiency(self, Z_microtubule: float = 1000) -> float:
        """
        Calculate power coupling efficiency between Obelisk and microtubule.
        
        Uses impedance matching formula: κ = 4Z1Z2/|Z1+Z2|²
        
        Args:
            Z_microtubule: Electromagnetic impedance of microtubule (Ω)
            
        Returns:
            Coupling efficiency (0-1)
        """
        # Estimate Obelisk impedance
        Z_obelisk = self.Z0 / np.sqrt(self.obelisk.params.epsilon_r)
        
        # Impedance matching
        numerator = 4 * Z_obelisk * Z_microtubule
        denominator = np.abs(Z_obelisk + Z_microtubule)**2
        
        match_efficiency = numerator / denominator
        
        # Include evanescent coupling
        evanescent = self.obelisk.evanescent_field()
        
        return match_efficiency * evanescent
    
    def phase_preservation(self, toxin_level: float = 0) -> float:
        """
        Calculate phase coherence preservation.
        
        Args:
            toxin_level: Relative concentration of toxins (0-1)
            
        Returns:
            Phase preservation factor (0-1)
        """
        # Base phase coherence
        Q = self.obelisk.quality_factor()
        base_preservation = 1 - 1/(2 * Q)
        
        # Toxin effects (empirical model)
        if toxin_level > 0:
            # Heavy metals cause decoherence
            decoherence = toxin_level * 0.5
            preservation = base_preservation * (1 - decoherence)
        else:
            preservation = base_preservation
            
        return max(0, min(1, preservation))
    
    def g2_coherence(self, toxin_level: float = 0,
                     mineral_status: str = 'replete') -> float:
        """
        Predict second-order coherence function g⁽²⁾(0).
        
        Args:
            toxin_level: Relative toxin concentration
            mineral_status: 'replete', 'deficient', or 'absent'
            
        Returns:
            Predicted g⁽²⁾(0) value
        """
        base_g2 = 1.0  # Coherent state baseline
        
        # Mineral effects
        if mineral_status == 'deficient':
            base_g2 = 1.5  # Mixed state
        elif mineral_status == 'absent':
            base_g2 = 2.0  # Thermal state
            
        # Toxin effects increase decoherence
        if toxin_level > 0:
            base_g2 = base_g2 + toxin_level * 0.5
            
        return min(2.0, base_g2)  # Cap at thermal limit


