GitHub Actions Workflow for Auto-Zenodo Release

```yaml
# .github/workflows/zenodo-release.yml
name: Zenodo Release

on:
  release:
    types: [published]

jobs:
  zenodo:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Validate Zenodo metadata
        run: |
          python -c "import json; json.load(open('.zenodo.json'))"
          echo "✓ Metadata valid"
      
      - name: Archive to Zenodo
        env:
          ZENODO_TOKEN: ${{ secrets.ZENODO_TOKEN }}
        run: |
          # Create deposition
          curl -X POST \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $ZENODO_TOKEN" \
            -d '{"metadata": '$(cat .zenodo.json)'}' \
            https://zenodo.org/api/deposit/depositions > deposition.json
          
          DEPOSITION_ID=$(jq -r .id deposition.json)
          echo "Created deposition: $DEPOSITION_ID"
          
          # Upload code archive
          zip -r macachor-9-source.zip . -x "*.git*" -x "node_modules/*"
          
          curl -X POST \
            -H "Authorization: Bearer $ZENODO_TOKEN" \
            -F "file=@macachor-9-source.zip" \
            "https://zenodo.org/api/deposit/depositions/$DEPOSITION_ID/files"
          
          # Publish
          curl -X POST \
            -H "Authorization: Bearer $ZENODO_TOKEN" \
            "https://zenodo.org/api/deposit/depositions/$DEPOSITION_ID/actions/publish"
```

