# Trigger death
trigger = {
    "type": "biometric",
    "timestamp": datetime.utcnow().isoformat() + "Z",
    "signature": "0x" + "a" * 64,
    "heartbeat": 0,
    "device_id": "simulator-01"
}

print(f"Killing node: {victim}")
response = requests.post(f"{victim}/trigger", json=trigger)
assert response.status_code == 200

# Monitor propagation
start = time.time()
archive_seen = {}
while len(archive_seen) < 9 and (time.time() - start) < 300:
    for node in nodes:
        if node == victim:
            continue
        try:
            r = requests.get(f"{node}/archive/latest", timeout=2)
            if r.status_code == 200:
                archive_seen[node] = r.json()
        except:
            pass
    time.sleep(5)
    print(f"Propagated to {len(archive_seen)}/9 nodes after {time.time()-start:.1f}s")

print(f"Propagation complete: {len(archive_seen)}/9 nodes in {time.time()-start:.1f}s")
