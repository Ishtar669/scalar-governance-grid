def test_invalid_biometric_trigger():
    trigger = {
        "type": "biometric",
        "timestamp": "2025-01-01T12:00:00Z",
        "signature": "0x" + "a" * 64,
        # Missing heartbeat
        "device_id": "fitbit-abc123"
    }
    valid, msg = validate_trigger(trigger)
