```python
import yaml
import json
from pathlib import Path
from jsonschema import validate, ValidationError
import datetime

def load_spec():
    """Load the DMS-1.0 specification from the embedded YAML."""
    spec_path = Path(__file__).parent / "spec.yaml"
    with open(spec_path, 'r') as f:
        return yaml.safe_load(f)

def validate_trigger(trigger_dict):
    """
    Validate a death trigger against DMS-1.0.
    
    Args:
        trigger_dict: Dict with type, timestamp, signature, and type-specific fields
    
    Returns:
        (bool, str): (is_valid, error_message)
    """
    spec = load_spec()
    
    # Check required top-level fields
    required = ['type', 'timestamp', 'signature']
    for field in required:
        if field not in trigger_dict:
            return False, f"Missing required field: {field}"
    
    # Validate timestamp is recent (within 5 minutes) or reasonable
    try:
        ts = datetime.datetime.fromisoformat(trigger_dict['timestamp'].replace('Z', '+00:00'))
        now = datetime.datetime.now(datetime.timezone.utc)
        delta = abs((now - ts).total_seconds())
        if delta > 300:  # 5 minutes
            return False, f"Timestamp too old: {delta} seconds"
    except:
        return False, "Invalid timestamp format (use ISO 8601)"
    
    # Validate type-specific fields
    trigger_type = trigger_dict['type']
    if trigger_type not in spec['triggers']['types']:
        return False, f"Invalid trigger type: {trigger_type}"
    
    rules = spec['triggers']['rules'].get(trigger_type, {})
    for field, constraints in rules.items():
        if constraints.get('required', False) and field not in trigger_dict:
            return False, f"Missing {trigger_type}-specific field: {field}"
        
        if field in trigger_dict:
            value = trigger_dict[field]
            if 'type' in constraints:
                if constraints['type'] == 'integer' and not isinstance(value, int):
                    return False, f"{field} must be integer"
                elif constraints['type'] == 'string' and not isinstance(value, str):
                    return False, f"{field} must be string"
                elif constraints['type'] == 'array' and not isinstance(value, list):
                    return False, f"{field} must be array"
            
            if 'min' in constraints and value < constraints['min']:
                return False, f"{field} below minimum {constraints['min']}"
            if 'max' in constraints and value > constraints['max']:
                return False, f"{field} above maximum {constraints['max']}"
            if 'min_items' in constraints and len(value) < constraints['min_items']:
                return False, f"{field} has fewer than {constraints['min_items']} items"
            if 'pattern' in constraints:
                import re
                if not re.match(constraints['pattern'], value):
                    return False, f"{field} does not match pattern {constraints['pattern']}"
    
    # Signature validation would go here (crypto)
    # For now, just check it's a non-empty string
    if not trigger_dict['signature'] or len(trigger_dict['signature']) < 10:
        return False, "Signature too short or empty"
    
    return True, "Valid"

def create_manifest(cid, arweave_tx, public_key):
    """Create a valid DMS manifest."""
    return {
        "version": "1.0",
        "cid": cid,
        "arweave_tx": arweave_tx,
        "public_key": public_key,
        "timestamp": datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z'),
        "hash": "pending"  # Would be SHA256 of archive contents
    }
```

